{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "mkdir -p public && cp -r ../data/processed/. public/ && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$RENDER_API_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
